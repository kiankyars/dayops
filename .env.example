# Model (server-global)
GEMINI_MODELS=gemini-3-flash-preview,gemini-2.5-flash,gemini-2.5-flash-lite
GEMINI_API_KEY=

# Backend
PORT=8000
DAYOPS_STORAGE_ROOT=.dayops_state

# Google OAuth web app
# Option A: set env vars below
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Option B: omit above and place JSON at .dayops_state/client_secret.json (or ./client_secret.json)
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/auth/google/callback
DEFAULT_USER_TIMEZONE=America/Los_Angeles

# Optional: only needed for direct CLI usage (not required for /ingest API flow)
DAYOPS_STATE_DIR=.dayops_state/local/state
DAYOPS_SNAPSHOT_DIR=.dayops_state/local/state/snapshots
GOOGLE_OAUTH_TOKEN_PATH=.dayops_state/local/google_oauth_token.json
GOOGLE_CALENDAR_ID=primary
TIMEZONE=America/Los_Angeles
